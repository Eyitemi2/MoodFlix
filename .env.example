# ─── TMDB (The Movie Database) ───────────────────────────────────────────────
# Get your free API key at: https://www.themoviedb.org/settings/api
# Leave blank to use mock data
TMDB_API_KEY=

# ─── Database ─────────────────────────────────────────────────────────────────
# Neon PostgreSQL (recommended for Vercel): https://neon.tech
# Supabase alternative: https://supabase.com
DATABASE_URL=postgresql://user:password@host:5432/moodflix?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@host:5432/moodflix

# ─── NextAuth.js ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-super-secret-key-here-minimum-32-chars
NEXTAUTH_URL=http://localhost:3000

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=MoodFlix

# ─── Optional: Vercel KV (Rate Limiting Cache) ────────────────────────────────
# Configure in Vercel dashboard: Storage → KV
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
